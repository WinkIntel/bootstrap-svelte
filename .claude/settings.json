{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(pnpm install)",
      "Bash(pnpm dev)",
      "Bash(pnpm build)",
      "Bash(pnpm preview)",
      "Bash(pnpm check-types)",
      "Bash(pnpm check-types:watch)",
      "Bash(pnpm lint)",
      "Bash(pnpm format)",
      "Bash(pnpm format-all)",
      "Bash(pnpm test)",
      "Bash(pnpm test:unit)",
      "Bash(pnpm test:unit-watch)",
      "Bash(pnpm vitest *)",
      "Bash(pnpm exec *)",
      "Bash(pnpm --version)",
      "Bash(npm pack --dry-run)",
      "Bash(npx publint *)"
    ]
  }
}